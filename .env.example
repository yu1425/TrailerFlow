# --- Supabase ---
# Public values (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secret. NEVER expose this to the client.
SUPABASE_SERVICE_ROLE_KEY=

# --- TMDb ---
# v4 API "API Read Access Token". Used as a Bearer token. Server-only.
TMDB_ACCESS_TOKEN=

# --- Admin ---
# Optional. When set, /api/admin/sync/tmdb requires
# "Authorization: Bearer <ADMIN_SECRET>".
ADMIN_SECRET=

# --- YouTube Data API ---
# Required for the YouTube candidate import script (scripts/import-youtube-candidates.ts).
# Get one at https://console.cloud.google.com/ → APIs & Services → YouTube Data API v3.
YOUTUBE_API_KEY=

# --- Data mode ---
# Controls which data source powers the feed AND which channels appear in the UI.
#   "manual" — curated contents only (recommended for public beta)
#   "tmdb"   — TMDb movies only (personal exploration mode)
#   "mixed"  — curated contents first, TMDb as fallback
#   "firehose" — approved contents + firehose-visible discovery candidates
# Set BOTH variables to the same value. DATA_MODE drives the server/API;
# NEXT_PUBLIC_DATA_MODE drives the client UI (channel list, TMDb badge).
# Production (Vercel) must always be "manual".
DATA_MODE=mixed
NEXT_PUBLIC_DATA_MODE=mixed

# --- Public site / SNS ---
# Absolute base URL of the deployment. Used for OGP/Twitter card absolute URLs.
NEXT_PUBLIC_SITE_URL=https://trailerflow.example
# X (Twitter) handle (without @) for the follow CTA.
NEXT_PUBLIC_X_HANDLE=trailerflow

# --- Dev tooling ---
# Set to "true" to show the on-screen KPI debug panel during real-device
# testing. Leave empty / unset in production.
NEXT_PUBLIC_DEBUG_PANEL=
